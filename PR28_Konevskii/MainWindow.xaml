<Window x:Class="PR28_Konevskii.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR28_Konevskii"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10,10,10,9">
            <Button Content="Пк клубы" Click="OpenPcClubs" Height="26" Width="100" Background="Green" Margin="0,0,16,0"/>
            <Button Content="Арендованные пк" Click="OpenPcRent" Height="26" Width="150" Background="Green"/>
        </StackPanel>
        <Frame x:Name="frame" Grid.Row="1" NavigationUIVisibility="Hidden" Margin="10,0,10,10" />
    </Grid>
</Window>
