<Page x:Class="PR28_Konevskii.Pages.pcrent.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR28_Konevskii.Pages.pcrent"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" Margin="5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="parent">

            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="1" Content="Добавить" Click="AddRecord" Margin="0,0,10,10" Background="Green" Height="25" Width="100" HorizontalAlignment="Right"/>
    </Grid>
</Page>
