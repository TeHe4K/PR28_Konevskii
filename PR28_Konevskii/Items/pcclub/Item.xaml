<UserControl x:Class="PR28_Konevskii.Items.pcclub.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PR28_Konevskii.Items.pcclub"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Gainsboro">
        <Grid Margin="20" Background="White" MinHeight="170">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image Grid.RowSpan="5" Width="80" Height="80" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" Source="/Images/ic_image.png"/>
            <Label Content="Наименование:" Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="10"/>
            <TextBox Height="25" x:Name="name" Grid.Column="1" Grid.Row="1" Margin="10,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
            <Label Content="Адрес:" Grid.Column="1" Grid.Row="2" VerticalAlignment="Top" Margin="10"/>
            <TextBox Height="25" x:Name="adres" Grid.Column="1" Grid.Row="3" Margin="10,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
            <Label Content="Время начала работы:" Grid.Column="2" Grid.Row="0" VerticalAlignment="Top" Margin="10"/>
            <TextBox Height="24" x:Name="timeStart" Grid.Column="2" VerticalAlignment="Center" IsEnabled="False" Grid.Row="1" Margin="10,0,10,0"/>
            <Label Content="Время окончания работы" Grid.Column="2" Grid.Row="2" VerticalAlignment="Top" Margin="10"/>
            <TextBox Height="25" x:Name="timeEnd" Grid.Column="2" Grid.Row="3" Margin="10,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
            <Button Content="Изменить" Click="EditRecord" Grid.Row="3" Height="25" Margin="0,10,0,0" HorizontalAlignment="Center" Width="100" Background="Green" VerticalAlignment="Top"/>
            <Button Content="Удалить" Click="DeleteRecord" Grid.Row="4" Height="25" Margin="0,10,0,10" HorizontalAlignment="Center" Width="100" Background="Orange" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</UserControl>
