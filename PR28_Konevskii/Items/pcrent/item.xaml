<UserControl x:Class="PR28_Konevskii.Items.pcrent.item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PR28_Konevskii.Items.pcrent"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Gainsboro">
        <Grid Margin="20" Background="White" MinHeight="170">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image Grid.RowSpan="5" Width="80" Height="80" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" Source="/Images/ic_image.png"/>
            <Label Content="Пк клуб" Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="10"/>
            <ComboBox Height="25" x:Name="PcClubs" Grid.Column="1" Grid.Row="1" Margin="10,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
            <Label Content="Фио" Grid.Column="1" Grid.Row="2" VerticalAlignment="Top" Margin="10"/>
            <TextBox Height="25" x:Name="FIO" Grid.Column="1" Grid.Row="3" Margin="10,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
            <Label Content="Дата аренды " Grid.Column="2" Grid.Row="0" VerticalAlignment="Top" Margin="10"/>
            <Grid Grid.Column="2" Grid.Row="1" Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <DatePicker Height="25" x:Name="date" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
                <TextBox Height="24" x:Name="time" Grid.Column="1" VerticalAlignment="Top" IsEnabled="False"/>
            </Grid>
            <Label Content="Продолжительность аренды" Grid.Column="2" Grid.Row="2" VerticalAlignment="Top" Margin="10"/>
            <TextBox Height="25" x:Name="Rent_Time" Grid.Column="2" Grid.Row="3" Margin="10,0,10,0" VerticalAlignment="Top" IsEnabled="False"/>
            <Button Content="Изменить" Click="EditRecord" Grid.Row="3" Height="25" Margin="0,10,0,0" HorizontalAlignment="Center" Width="100" Background="Green" VerticalAlignment="Top"/>
            <Button Content="Удалить" Click="DeleteRecord" Grid.Row="4" Height="25" Margin="0,10,0,10" HorizontalAlignment="Center" Width="100" Background="Orange" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</UserControl>
